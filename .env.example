# DataScout Agent local configuration
# Copy this file to .env and keep real credentials out of Git.

# Flask / WSGI
BAA_HOST=0.0.0.0
AGENT_PORT=5001
BAA_WSGI=waitress
BAA_SKIP_DEPENDENCY_CHECK=1

# Runtime storage. Leave empty for project-local storage.
# For Docker or production, use an absolute persistent path.
# BAA_DATA_DIR=/absolute/path/to/datascout-data

# Set a long random value in production so authenticated browser sessions
# remain valid after container restarts.
BAA_AUTH_SECRET=

# Deployment-only model service credentials. Never collect these from end users
# or expose them to browser code. Configure at least one on the server.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ATLASCLOUD_API_KEY=

# Anthropic or an Anthropic-compatible gateway.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=

# Usage protection
BAA_USER_DAILY_MESSAGE_LIMIT=30
BAA_GUEST_DAILY_MESSAGE_LIMIT=5
BAA_USER_MAX_CONCURRENCY=1
BAA_USER_FAILURE_LIMIT=5
BAA_USER_BLOCK_SECONDS=1800
